{
  "name": "selection-qx",
  "description": "Web application intended for school staff, designed to make it easier to manage student applications.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:server": "cd apps/server && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build": "bun -b --filter '*' build",
    "lint": "bun --filter '*' type-check && bunx eslint \"**/*.{js,ts,html,vue,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,html,vue,css,json}\""
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "prettier": {
    "singleQuote": false,
    "printWidth": 100,
    "endOfLine": "crlf",
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  }
}
